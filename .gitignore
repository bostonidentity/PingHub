# Monorepo-level ignores. Project-specific rules live in each
# project's own .gitignore (e.g. aic-pipeline/.gitignore).

# OS
.DS_Store
Thumbs.db

# IDE / editors
.vscode/
.idea/
*.swp

# Claude Code / local tooling
.claude/
.superpowers/
.worktrees/
.playwright-mcp/

# Vercel
.vercel

# Env files — never commit, any project, anywhere
.env*

# Secrets / keys
*.pem

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
